datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Session {
  id       Int      @id @default(autoincrement())
  category String
  duration Int
  ts       DateTime @default(now())
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  color String
}