datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  password   String?
}

model Session {
  id       Int      @id @default(autoincrement())
  userId   Int      @default(1)
  category String
  duration Int
  note     String?
  ts       DateTime @default(now())
}

model Category {
  id       Int    @id @default(autoincrement())
  userId   Int    @default(1)
  name     String
  color    String
}